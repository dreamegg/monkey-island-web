{
  "id": "harbor",
  "startNode": "start",
  "nodes": {
    "start": {
      "id": "start",
      "speaker": "등대지기",
      "portrait": "/assets/portraits/bartender_suspicious.png",
      "text": "어서오게, 젊은이. 이 섬에 처음 오는 건가?",
      "choices": [
        { "text": "네, 처음 왔습니다. 여기가 어딘가요?", "next": "where" },
        { "text": "흑진주를 찾고 있습니다.", "next": "pearl", "condition": "intro_done" },
        { "text": "아니요, 그냥 지나가는 길입니다.", "next": "bye" }
      ]
    },
    "where": {
      "id": "where",
      "speaker": "등대지기",
      "portrait": "/assets/portraits/bartender_suspicious.png",
      "text": "여긴 그림자 섬이라네. 아름다운 섬이지만... 오래된 저주가 걸려있어.",
      "onEnter": [
        { "cmd": "set_flag", "flag": "intro_done", "value": true }
      ],
      "next": "curse"
    },
    "curse": {
      "id": "curse",
      "speaker": "등대지기",
      "portrait": "/assets/portraits/bartender_suspicious.png",
      "text": "전설의 흑진주가 이 섬 어딘가에 있다네. 하지만 찾으려면 세 가지 수수께끼를 풀어야 해.",
      "choices": [
        { "text": "세 가지 수수께끼가 뭔가요?", "next": "riddles" },
        { "text": "저주가 뭔가요?", "next": "what_curse" }
      ]
    },
    "riddles": {
      "id": "riddles",
      "speaker": "등대지기",
      "portrait": "/assets/portraits/bartender_suspicious.png",
      "text": "첫째, 신전 수호자의 수수께끼. 둘째, 선녀의 시험. 셋째, 거울의 비밀이라네. 용기있게 도전해보게!",
      "onEnter": [
        { "cmd": "set_flag", "flag": "knows_riddles", "value": true }
      ],
      "next": "key_hint"
    },
    "key_hint": {
      "id": "key_hint",
      "speaker": "등대지기",
      "portrait": "/assets/portraits/bartender_suspicious.png",
      "text": "수수께끼를 모두 풀면 내 열쇠를 드리겠네. 그게 있어야 등대 꼭대기에 올라갈 수 있거든.",
      "choices": [
        { "text": "감사합니다! 꼭 해보겠습니다.", "next": "end" },
        { "text": "지금 열쇠를 주실 수 없나요?", "next": "no_key_yet" }
      ]
    },
    "no_key_yet": {
      "id": "no_key_yet",
      "speaker": "등대지기",
      "portrait": "/assets/portraits/bartender_suspicious.png",
      "text": "하하, 수수께끼도 안 풀었는데 열쇠를 달라고? 먼저 신전에 가보게나.",
      "next": "end"
    },
    "what_curse": {
      "id": "what_curse",
      "speaker": "등대지기",
      "portrait": "/assets/portraits/bartender_suspicious.png",
      "text": "흑진주를 탐낸 자는 섬에서 영원히 떠날 수 없게 되는 저주라네... 하지만 올바른 마음으로 찾으면 괜찮다고 전해지지.",
      "next": "curse"
    },
    "pearl": {
      "id": "pearl",
      "speaker": "등대지기",
      "portrait": "/assets/portraits/bartender_suspicious.png",
      "text": "오호! 흑진주를 찾겠다고? 대단한 용기군. 수수께끼들을 다 풀었나?",
      "choices": [
        { "text": "네, 다 풀었습니다.", "next": "give_key", "condition": "knows_riddles" },
        { "text": "아직 다 못 풀었습니다.", "next": "not_yet" }
      ]
    },
    "give_key": {
      "id": "give_key",
      "speaker": "등대지기",
      "portrait": "/assets/portraits/bartender_suspicious.png",
      "text": "훌륭하네! 약속대로 열쇠를 드리겠네. 등대 꼭대기의 거울이 길을 보여줄 거야.",
      "onEnter": [
        { "cmd": "give_item", "id": "lighthouse_key", "name": "등대 열쇠", "icon": "🗝️" },
        { "cmd": "set_flag", "flag": "has_lighthouse_key", "value": true }
      ],
      "next": "end"
    },
    "not_yet": {
      "id": "not_yet",
      "speaker": "등대지기",
      "portrait": "/assets/portraits/bartender_suspicious.png",
      "text": "서두르지 말게. 신전에서 동굴, 해변을 모두 돌아봐야 해. 준비가 되면 다시 오게나.",
      "next": "end"
    },
    "bye": {
      "id": "bye",
      "speaker": "등대지기",
      "portrait": "/assets/portraits/bartender_suspicious.png",
      "text": "그런가. 조심해서 다니게나. 이 섬은 생각보다 복잡하다네.",
      "next": "end"
    },
    "end": {
      "id": "end",
      "speaker": "등대지기",
      "portrait": "/assets/portraits/bartender_suspicious.png",
      "text": "행운을 빌겠네, 젊은이."
    }
  }
}
